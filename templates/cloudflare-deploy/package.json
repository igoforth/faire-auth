{
  "name": "faire-auth-cloudflare-template",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "cloudflare": {
    "bindings": {
      "FAIRE_AUTH_SECRET": {
        "description": "Generate with `npx @faire-auth/cli secret`."
      },
      "GITHUB_CLIENT_ID": {
        "description": "(Optional) GitHub OAuth app client ID."
      },
      "GITHUB_CLIENT_SECRET": {
        "description": "(Optional) GitHub OAuth app client secret."
      },
      "GOOGLE_CLIENT_ID": {
        "description": "(Optional) Google OAuth app client ID."
      },
      "GOOGLE_CLIENT_SECRET": {
        "description": "(Optional) Google OAuth app client secret."
      },
      "FAIRE_AUTH_URL": {
        "description": "Your public worker URL, e.g. `https://faire-auth-cloudflare.your-subdomain.workers.dev`"
      }
    }
  },
  "exports": {
    "./client": {
      "import": {
        "types": "./dist/client/index.d.mts",
        "default": "./dist/client/index.mjs"
      },
      "require": {
        "types": "./dist/client/index.d.cts",
        "default": "./dist/client/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "cli:generate": "cli generate --output src/schema.ts",
    "drizzle:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply FAIRE_AUTH_DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply FAIRE_AUTH_DB --remote",
    "dev": "wrangler dev",
    "predeploy": "npm run cli:generate -- -y && npm run drizzle:generate",
    "deploy": "npm run db:migrate:remote && wrangler deploy",
    "typegen": "wrangler types"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.7",
    "faire-auth": "latest",
    "hono": "^4.12.7"
  },
  "devDependencies": {
    "@better-fetch/fetch": "^1.1.18",
    "@faire-auth/cli": "latest",
    "@faire-auth/core": "latest",
    "drizzle-kit": "^0.31.4",
    "nanostores": "^1.0.1",
    "tsdown": "^0.16.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.46.0"
  }
}
