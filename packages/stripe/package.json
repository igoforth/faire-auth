{
  "name": "@faire-auth/stripe",
  "author": "Bereket Engida",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "stripe",
    "auth",
    "stripe"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/igoforth/faire-auth.git",
    "directory": "packages/stripe"
  },
  "description": "Stripe plugin for Faire Auth",
  "scripts": {
    "test": "vitest",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --project tsconfig.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./client": {
      "dev-source": "./src/client.ts",
      "import": {
        "types": "./dist/client.d.mts",
        "default": "./dist/client.mjs"
      },
      "require": {
        "types": "./dist/client.d.cts",
        "default": "./dist/client.cjs"
      }
    }
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@faire-auth/core": "workspace:*",
    "faire-auth": "workspace:*",
    "stripe": "^18 || ^19",
    "hono": ">=4.3.6"
  },
  "devDependencies": {
    "@faire-auth/core": "workspace:*",
    "faire-auth": "workspace:*",
    "stripe": "catalog:",
    "tsdown": "catalog:",
    "publint": "catalog:"
  }
}
