{
  "name": "@faire-auth/expo",
  "version": "1.0.3",
  "type": "module",
  "description": "Faire Auth integration for Expo and React Native applications.",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/igoforth/faire-auth.git",
    "directory": "packages/expo"
  },
  "homepage": "https://www.faire-auth.com/docs/integrations/expo",
  "scripts": {
    "test": "vitest",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --project tsconfig.json"
  },
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./client": {
      "dev-source": "./src/client.ts",
      "import": {
        "types": "./dist/client.d.mts",
        "default": "./dist/client.mjs"
      },
      "require": {
        "types": "./dist/client.d.cts",
        "default": "./dist/client.cjs"
      }
    }
  },
  "keywords": [
    "auth",
    "expo",
    "react-native",
    "typescript",
    "faire-auth"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "devDependencies": {
    "@better-fetch/fetch": "catalog:",
    "better-sqlite3": "catalog:",
    "expo-constants": "~17.1.7",
    "expo-crypto": "^13.0.2",
    "expo-linking": "~7.1.7",
    "expo-secure-store": "~14.2.3",
    "expo-web-browser": "~14.2.0",
    "faire-auth": "workspace:*",
    "publint": "catalog:",
    "react-native": "^0.84.1",
    "tsdown": "catalog:"
  },
  "peerDependencies": {
    "@faire-auth/core": "workspace:*",
    "expo-constants": ">=17.0.0",
    "expo-crypto": ">=13.0.0",
    "expo-linking": ">=7.0.0",
    "expo-secure-store": ">=14.0.0",
    "expo-web-browser": ">=14.0.0",
    "faire-auth": "workspace:*"
  },
  "dependencies": {
    "@better-fetch/fetch": "catalog:",
    "zod": "catalog:"
  },
  "files": [
    "dist"
  ]
}
